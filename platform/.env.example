# ─── Database ────────────────────────────────────────────────────────────────
# Local dev (SQLite): keep as-is. schema.prisma provider must be "sqlite".
# Production (Postgres): set a postgres URL and change provider to "postgresql".
#   e.g. postgres://user:pass@host/db?sslmode=require   (Neon / Supabase)
DATABASE_URL="file:./dev.db"

# ─── Platform ────────────────────────────────────────────────────────────────
# Your platform's root domain. Tenants live on subdomains of this.
# Dev: localhost:3000   Prod: yourdomain.com
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# Secret for signing admin/session cookies (use a long random string in prod).
AUTH_SECRET="change-me-to-a-long-random-string"

# ─── Razorpay (payments) ─────────────────────────────────────────────────────
# Leave empty to run checkout in mock/test mode (no real charge).
# Fill both to accept live payments. dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# ─── Image uploads (production) ──────────────────────────────────────────────
# On Vercel, set this to store uploads in Vercel Blob (Storage → Blob → token).
# Leave empty for local dev (saves to public/uploads).
BLOB_READ_WRITE_TOKEN=""
